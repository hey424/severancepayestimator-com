---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  pageSchema?: any;
}

const { title, description, canonical, image, pageSchema } = Astro.props;

// Site constants
const siteUrl = "https://severancepayestimator.com";
const siteName = "Severancepayestimator";
const brandName = "Severancepayestimator";
const publisherName = "The Click Lab Agency LLC";
const publisherUrl = "https://theclicklab.agency";

// Editor / reviewer — matches the named bylines on methodology and editorial pages
const editorInChief = {
  name: "Sloan Whitfield",
  credentials: "SHRM-CP",
  role: "Editor-in-Chief & Separation Agreements Lead",
  bio: "Sloan Whitfield (SHRM-CP) is the Editor-in-Chief & Separation Agreements Lead of Severancepayestimator, overseeing methodology and editorial standards.",
  url: `${siteUrl}/editorial/`,
};

const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ? new URL(image, siteUrl).toString() : new URL('/og-default.png', siteUrl).toString();

const organizationSchema = {
  '@type': 'Organization',
  '@id': `${publisherUrl}/#organization`,
  name: publisherName,
  url: publisherUrl,
  legalName: publisherName,
};

const personSchema = {
  '@type': 'Person',
  '@id': `${siteUrl}/#editor-in-chief`,
  name: editorInChief.name,
  honorificSuffix: editorInChief.credentials,
  jobTitle: editorInChief.role,
  description: editorInChief.bio,
  url: editorInChief.url,
  worksFor: { '@id': `${publisherUrl}/#organization` },
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: siteName,
  alternateName: brandName,
  publisher: { '@id': `${publisherUrl}/#organization` },
  inLanguage: 'en-US',
};

const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [organizationSchema, personSchema, websiteSchema],
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)}></script>
    {pageSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(pageSchema)}></script>
    )}
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6434377544325972" crossorigin="anonymous"></script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SMLL1SY96M"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-SMLL1SY96M');</script>
  </head>
<body>
  <header class="site-header">
    <nav class="nav-inner">
      <a class="site-logo" href="/">Severance<span>Calc</span></a>
      <ul class="nav-links">
        <li><a href="/">Calculator</a></li>
        <li><a href="/case-types/">Pay Types</a></li>
        <li><a href="/guides/">Guides</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <ul class="footer-nav">
        <li><a href="/about/">About</a></li>
        <li><a href="/methodology/">Methodology</a></li>
        <li><a href="/editorial/">Editorial Team</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/faq/">FAQ</a></li>
        <li><a href="/privacy/">Privacy</a></li>
        <li><a href="/terms/">Terms</a></li>
      </ul>
      <p class="footer-credit">&copy; 2026 The Click Lab &mdash; Reviewed by the Editorial Team. Informational only, not legal advice.</p>
    </div>
  </footer>
</body>
</html>